# ─── DB Adapter ──────────────────────────────────────────────────────────────
# The app auto-selects a DB adapter based on which variable is set:
#   DATABASE_URL  → Neon (serverless Postgres) — for production / Vercel
#   OCDS_DATA_DIR → DuckDB in-memory CSVs     — for local development
# Set only one. If both are set, DATABASE_URL takes precedence.

# Ruta absoluta a la carpeta con los CSV del OCDS Guatecompras
# Descarga los datos en: https://datos.minfin.gob.gt/dataset/ocds-guatecompras
# Descomprime y apunta a la carpeta que contiene main.csv, awards.csv, etc.
OCDS_DATA_DIR=/ruta/a/tu/carpeta/gt_2024/2024

# Neon (Postgres) connection string — get it from neon.tech dashboard
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# Para generación de borradores periodísticos con IA
MINIMAX_API_KEY=
# Opcional: override del modelo de texto
MINIMAX_MODEL=MiniMax-M2.7
